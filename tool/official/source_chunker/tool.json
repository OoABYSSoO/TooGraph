{
  "schemaVersion": "toograph.tool/v1",
  "toolKey": "source_chunker",
  "name": "Source Chunker",
  "description": "把规范化 Buddy 消息或规范化文档转换为可入库、可召回的确定性切片候选；不会写入存储，也不会排队 embedding。",
  "version": "0.1.0",
  "timeoutSeconds": 30,
  "permissions": [],
  "runtime": {
    "type": "python",
    "entrypoint": "run.py",
    "timeoutSeconds": 30
  },
  "inputPresentation": {
    "source_kind": {
      "mode": "static",
      "control": "select",
      "default": "buddy_messages",
      "options": [
        {
          "label": "Chat history",
          "value": "buddy_messages",
          "updates": {
            "strategy": "conversation_turn_window",
            "limits": {
              "max_chars": 2400,
              "max_turns_per_chunk": 3,
              "overlap_messages": 0
            }
          }
        },
        {
          "label": "Knowledge documents",
          "value": "normalized_documents",
          "updates": {
            "strategy": "document_section_window",
            "limits": {
              "max_chars": 1800,
              "overlap_chars": 200
            }
          }
        }
      ]
    },
    "strategy": {
      "mode": "static",
      "control": "select",
      "default": "conversation_turn_window",
      "options": [
        {
          "label": "Conversation turns",
          "value": "conversation_turn_window"
        },
        {
          "label": "Document sections",
          "value": "document_section_window"
        }
      ]
    },
    "source": {
      "mode": "state"
    },
    "limits": {
      "mode": "static",
      "control": "object",
      "default": {
        "max_chars": 2400,
        "max_turns_per_chunk": 3,
        "overlap_messages": 0
      },
      "properties": [
        {
          "key": "max_chars",
          "name": "Max chars",
          "valueType": "number",
          "default": 2400,
          "min": 200,
          "step": 100
        },
        {
          "key": "max_turns_per_chunk",
          "name": "Max turns",
          "valueType": "number",
          "default": 3,
          "min": 1,
          "step": 1,
          "visibleWhen": {
            "field": "source_kind",
            "equals": "buddy_messages"
          }
        },
        {
          "key": "overlap_messages",
          "name": "Message overlap",
          "valueType": "number",
          "default": 0,
          "min": 0,
          "step": 1,
          "visibleWhen": {
            "field": "source_kind",
            "equals": "buddy_messages"
          }
        },
        {
          "key": "overlap_chars",
          "name": "Char overlap",
          "valueType": "number",
          "default": 200,
          "min": 0,
          "step": 20,
          "visibleWhen": {
            "field": "source_kind",
            "equals": "normalized_documents"
          }
        }
      ]
    }
  },
  "inputSchema": [
    {
      "key": "source_kind",
      "name": "Source Kind",
      "valueType": "text",
      "description": "来源类型：buddy_messages 或 normalized_documents。"
    },
    {
      "key": "strategy",
      "name": "Strategy",
      "valueType": "text",
      "description": "切片策略：消息使用 conversation_turn_window，规范化文档使用 document_section_window。"
    },
    {
      "key": "source",
      "name": "Source",
      "valueType": "json",
      "description": "规范化来源包；消息输入提供 session_id 和 messages，文档输入提供 documents。"
    },
    {
      "key": "limits",
      "name": "Limits",
      "valueType": "json",
      "description": "切片限制，例如 max_chars、overlap_chars、overlap_messages 和 max_turns_per_chunk。"
    }
  ],
  "outputSchema": [
    {
      "key": "chunks",
      "name": "Chunks",
      "valueType": "json",
      "description": "可用于检索入库的确定性切片候选。"
    }
  ],
  "localized": {
    "en-US": {
      "name": "Source Chunker",
      "description": "Converts normalized Buddy messages or normalized documents into deterministic retrieval-ready chunk candidates without writing storage or queueing embeddings."
    },
    "zh-CN": {
      "name": "源材料切片器",
      "description": "把规范化 Buddy 消息或规范化文档转换为可入库、可召回的确定性切片候选；不会写入存储，也不会排队 embedding。"
    }
  }
}
