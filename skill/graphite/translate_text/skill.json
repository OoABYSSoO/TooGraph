{
  "schemaVersion": "graphite.skill/v1",
  "skillKey": "translate_text",
  "label": "Translate Text",
  "description": "Translate text between languages while preserving tone and meaning.",
  "version": "1.0.0",
  "targets": ["agent_node"],
  "kind": "atomic",
  "mode": "tool",
  "scope": "node",
