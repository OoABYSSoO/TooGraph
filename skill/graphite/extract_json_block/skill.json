{
  "schemaVersion": "graphite.skill/v1",
  "skillKey": "extract_json_block",
  "label": "Extract JSON Block",
  "description": "Extract the first valid JSON object or array from model output or mixed text.",
  "version": "1.0.0",
  "targets": ["agent_node"],
  "kind": "atomic",
  "mode": "tool",
  "scope": "node",
  "permissions": [],
  "inputSchema": [
    {
      "key": "text",
      "label": "Text",
      "valueType": "text",
      "required": true,
      "description": "Text that may contain fenced or inline JSON."
    }
  ],
  "outputSchema": [
    {
      "key": "parsed",
      "label": "Parsed",
      "valueType": "json",
      "description": "Parsed JSON value, or null when parsing fails."
    },
    {
      "key": "valid",
      "label": "Valid",
      "valueType": "boolean",
      "description": "Whether JSON extraction succeeded."
    },
    {
      "key": "error",
      "label": "Error",
      "valueType": "text",
      "description": "Parsing error when extraction fails."
    }
  ],
  "supportedValueTypes": ["text", "json"],
  "sideEffects": ["none"],
  "runtime": {
    "type": "builtin",
    "entrypoint": "extract_json_block"
  },
  "health": {
    "type": "builtin"
  },
  "configured": true,
  "healthy": true
}
