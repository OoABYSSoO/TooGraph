{
  "schemaVersion": "graphite.skill/v1",
  "skillKey": "extract_json_fields",
  "label": "Extract JSON Fields",
  "description": "Parse unstructured text and extract specified fields into a structured JSON object.",
  "version": "1.0.0",
  "targets": ["agent_node"],
  "kind": "atomic",
  "mode": "tool",
  "scope": "node",
  "permissions": ["model_text"],
  "inputSchema": [
    {
      "key": "text",
      "label": "Text",
      "valueType": "text",
      "required": true,
      "description": "Source text to parse and extract fields from."
    },
    {
      "key": "fields",
      "label": "Fields",
      "valueType": "text",
      "required": true,
      "description": "Comma-separated field names to extract."
    }
  ],
  "outputSchema": [
    {
      "key": "extracted",
      "label": "Extracted",
      "valueType": "json",
      "description": "Object with requested field names as keys and extracted values."
    },
    {
      "key": "confidence",
      "label": "Confidence",
      "valueType": "text",
      "description": "Extraction confidence level."
    }
  ],
  "supportedValueTypes": ["text", "json"],
  "sideEffects": ["model_call"],
  "runtime": {
    "type": "builtin",
    "entrypoint": "extract_json_fields"
  },
  "health": {
    "type": "builtin"
  },
  "configured": true,
  "healthy": true
}
