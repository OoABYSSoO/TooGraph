#!/bin/bash
set -euo pipefail

SERVICE="lm-server.service"
DEFAULT_PROXY_PORT="8888"
DEFAULT_CONNECT_TIMEOUT="1"
DEFAULT_MAX_TIME="5"
READY_WAIT_SECONDS="120"
LM_CONFIG_DIR="${HOME}/.config/lm"
PROVIDER_ENV="${LM_PROVIDER_ENV:-$LM_CONFIG_DIR/provider.env}"

mkdir -p "$LM_CONFIG_DIR"
if [ -f "$PROVIDER_ENV" ]; then
  # shellcheck disable=SC1090
  . "$PROVIDER_ENV"
fi
: "${LM_CLOUD_PROVIDER:=or}"

normalize_provider_name() {
  case "${1:-}" in
    sub2|cc|sub2api)
      echo "sub2"
      ;;
    or|openrouter|"")
      echo "or"
      ;;
    *)
      return 1
      ;;
  esac
}

provider_label() {
  case "${1:-}" in
    sub2) echo "sub2api" ;;
    or) echo "OpenRouter" ;;
    *) echo "${1:-unknown}" ;;
  esac
}

provider_alias_prefix() {
  case "${1:-}" in
    sub2) echo "sub2" ;;
    or) echo "or" ;;
    *) echo "${1:-unknown}" ;;
  esac
}

LM_CLOUD_PROVIDER="$(normalize_provider_name "$LM_CLOUD_PROVIDER" 2>/dev/null || echo or)"

service_exists() {
  systemctl cat "$SERVICE" >/dev/null 2>&1
}

get_execstart() {
  systemctl cat "$SERVICE" 2>/dev/null | sed -n 's/^ExecStart=//p' | tail -n 1
}

get_exec_paths() {
  local execstart
  execstart="$(get_execstart)"
  if [ -z "$execstart" ]; then
    return 1
  fi

  python3 - "$execstart" <<'PY'
import shlex, sys
parts = shlex.split(sys.argv[1])
python_bin = parts[0] if parts else "python3"
script_path = parts[1] if len(parts) > 1 else ""
print(python_bin)
print(script_path)
PY
}

load_config_json() {
  local python_bin script_path
  mapfile -t _paths < <(get_exec_paths)
  python_bin="${_paths[0]:-python3}"
  script_path="${_paths[1]:-}"

  if [ -z "$script_path" ] || [ ! -f "$script_path" ]; then
    return 1
  fi

  "$python_bin" - "$script_path" <<'PY'
import json, runpy, sys
script_path = sys.argv[1]
ns = runpy.run_path(script_path, run_name="lm_core_config")
summary_fn = ns.get("summarize_runtime_config")
build_fn = ns.get("build_runtime_config")
if callable(summary_fn):
    cfg = summary_fn()
elif callable(build_fn):
    cfg = build_fn()
else:
    cfg = {
        "display_model_name": ns.get("LOCAL_MODEL_NAME", "lm-local"),
        "proxy": {
            "port": ns.get("PROXY_PORT", 8888),
            "url": f"http://127.0.0.1:{ns.get('PROXY_PORT', 8888)}",
            "healthz": f"http://127.0.0.1:{ns.get('PROXY_PORT', 8888)}/healthz",
            "logs_page": f"http://127.0.0.1:{ns.get('PROXY_PORT', 8888)}/logs",
        },
        "llama": {
            "port": ns.get("LLAMA_PORT", 8889),
            "url": f"http://127.0.0.1:{ns.get('LLAMA_PORT', 8889)}",
            "binary": ns.get("LLAMA_SERVER_BIN", ""),
            "model_path": ns.get("MODEL_PATH", ""),
            "ctx_size": ns.get("LLAMA_CTX_SIZE", None),
            "n_predict": ns.get("LLAMA_N_PREDICT", None),
        },
        "cloud": {
            "provider": ns.get("ACTIVE_CLOUD_PROVIDER", ns.get("LM_CLOUD_PROVIDER", "or")),
            "api_base": ((ns.get("ACTIVE_CLOUD_PROVIDER_CONFIG") or {}).get("api_base")
                         or ns.get("OPENROUTER_DIRECT_BASE")
                         or ns.get("OPENROUTER_API_BASE", "https://openrouter.ai/api")),
            "aliases": {
                "sonnet": ns.get("CLOUD_SONNET_ALIAS", ns.get("LM_ACTIVE_SONNET_ALIAS", "or-sonnet")),
                "opus": ns.get("CLOUD_OPUS_ALIAS", ns.get("LM_ACTIVE_OPUS_ALIAS", "or-opus")),
                "haiku": ns.get("CLOUD_HAIKU_ALIAS", ns.get("LM_ACTIVE_HAIKU_ALIAS", "or-haiku")),
            },
        },
        "logs": {
            "dir": ns.get("LOG_DIR", ""),
            "history": ns.get("HISTORY_LOG_FILE", ""),
        },
    }
print(json.dumps(cfg, ensure_ascii=False))
PY
}

extract_proxy_port() {
  local cfg_json="${1:-}"
  if [ -z "$cfg_json" ]; then
    echo "$DEFAULT_PROXY_PORT"
    return 0
  fi
  python3 - "$cfg_json" <<'PY'
import json, sys
try:
    cfg = json.loads(sys.argv[1])
    print(cfg.get("proxy", {}).get("port", 8888))
except Exception:
    print(8888)
PY
}

extract_active_provider() {
  local cfg_json="${1:-}"
  python3 - "$cfg_json" <<'PY'
import json, sys
try:
    cfg = json.loads(sys.argv[1]) if sys.argv[1] else {}
except Exception:
    cfg = {}
print(cfg.get("cloud", {}).get("provider", "or"))
PY
}

print_provider_list() {
  local cfg_json="${1:-}"
  python3 - "$cfg_json" "$PROVIDER_ENV" <<'PY'
import json, os, sys
cfg_raw, provider_env = sys.argv[1:3]
try:
    cfg = json.loads(cfg_raw) if cfg_raw else {}
except Exception:
    cfg = {}
runtime = cfg.get("runtime") or {}
cloud = cfg.get("cloud", {}) or runtime.get("cloud", {})
active = cloud.get("provider", "or")
providers = cloud.get("providers") or {}
if not providers:
    providers = {
        active: {
            "label": active,
            "api_base": cloud.get("api_base", ""),
            "auth_configured": True,
            "models": cloud.get("models", {}),
        }
    }
print(f"provider env: {provider_env}")
print(f"active provider: {active}")
aliases = cloud.get("aliases") or {}
if aliases:
    print(
        "claude-code aliases: "
        f"sonnet={aliases.get('sonnet', '-')} "
        f"opus={aliases.get('opus', '-')} "
        f"haiku={aliases.get('haiku', '-')}"
    )
for name, item in providers.items():
    marker = "*" if name == active else " "
    label = item.get("label") or name
    api_base = item.get("api_base") or "-"
    auth_state = "ok" if item.get("auth_configured") else "missing-auth"
    sonnet = (item.get("models") or {}).get("sonnet", "-")
    print(f"{marker} {name:6s} ({label}) api={api_base} auth={auth_state} sonnet={sonnet}")
PY
}

write_provider_env() {
  local provider="$1"
  mkdir -p "$(dirname "$PROVIDER_ENV")"
  cat >"$PROVIDER_ENV" <<EOF
# managed by lm
export LM_CLOUD_PROVIDER="$provider"
EOF
}

switch_provider_and_restart() {
  local provider="$1"
  local cfg_json proxy_port runtime_json
  write_provider_env "$provider"
  echo "📝 已写入 Claude Code provider 配置: $PROVIDER_ENV"
  echo "🔁 正在重启系统级服务 $SERVICE ..."
  sudo systemctl restart "$SERVICE"
  cfg_json="$(load_config_json 2>/dev/null || echo '{}')"
  proxy_port="$(extract_proxy_port "$cfg_json")"
  if wait_until_ready "$proxy_port"; then
    echo "🔀 Claude Code 云供应商已切换到: $provider ($(provider_label "$provider"))"
    runtime_json="$(load_runtime_json "$proxy_port")"
    print_provider_list "${runtime_json:-$cfg_json}"
  else
    echo "⏳ provider 已写入并重启服务，但接口暂未 ready。可执行 lm log 继续查看。"
    exit 1
  fi
}

load_runtime_json() {
  local port="$1"
  curl -fsS --connect-timeout "$DEFAULT_CONNECT_TIMEOUT" --max-time "$DEFAULT_MAX_TIME" \
    "http://127.0.0.1:${port}/healthz" 2>/dev/null || true
}

classify_runtime_state() {
  local runtime_json="${1:-}"
  local active_state="${2:-}"

  python3 - "$runtime_json" "$active_state" <<'PY'
import json, sys
runtime_raw, active_state = sys.argv[1:3]
try:
    runtime = json.loads(runtime_raw) if runtime_raw else {}
except Exception:
    runtime = {}

llama = runtime.get("llama_status")

if active_state != "active":
    mapping = {
        "inactive": "未运行",
        "failed": "失败",
        "activating": "启动中",
        "deactivating": "停止中",
    }
    print(mapping.get(active_state, active_state or "未知"))
    raise SystemExit

if not runtime:
    print("启动中")
    raise SystemExit

llama_ok = str(llama) == "200"

if llama_ok:
    print("运行中")
elif llama in (None, "", "未探测"):
    print("启动中")
else:
    print("异常")
PY
}

wait_until_ready() {
  local port="$1"
  local timeout="${2:-$READY_WAIT_SECONDS}"
  local start_ts now runtime_json state
  start_ts="$(date +%s)"

  while true; do
    runtime_json="$(load_runtime_json "$port")"
    state="$(classify_runtime_state "$runtime_json" "active")"
    if [ "$state" = "运行中" ]; then
      return 0
    fi

    now="$(date +%s)"
    if [ $((now - start_ts)) -ge "$timeout" ]; then
      return 1
    fi
    sleep 1
  done
}

print_panel() {
  local enabled_state active_state cfg_json proxy_port runtime_json runtime_state

  if ! service_exists; then
    echo "❌ 未找到 systemd 服务: $SERVICE"
    return 1
  fi

  enabled_state="$(systemctl is-enabled "$SERVICE" 2>/dev/null || true)"
  active_state="$(systemctl is-active "$SERVICE" 2>/dev/null || true)"
  cfg_json="$(load_config_json 2>/dev/null || echo '{}')"
  proxy_port="$(extract_proxy_port "$cfg_json")"
  runtime_json="$(load_runtime_json "$proxy_port")"
  runtime_state="$(classify_runtime_state "$runtime_json" "$active_state")"

  python3 - "$cfg_json" "$runtime_json" "$enabled_state" "$runtime_state" "$SERVICE" <<'PY'
import json, os, sys
cfg_raw, runtime_raw, enabled_state, runtime_state, service = sys.argv[1:6]

def j(s):
    try:
        return json.loads(s) if s else {}
    except Exception:
        return {}

cfg = j(cfg_raw)
runtime = j(runtime_raw)
summary = runtime.get("runtime") or cfg
llama = summary.get("llama", {})
proxy = summary.get("proxy", {})
cloud = summary.get("cloud", {})
logs = summary.get("logs", {})
pids = runtime.get("pids", {})


def pick(*vals):
    for v in vals:
        if v not in (None, "", {}):
            return v
    return "-"


def show_enabled(v):
    mapping = {
        "enabled": "已开启",
        "disabled": "已关闭",
        "static": "静态",
        "indirect": "间接",
        "generated": "生成",
        "transient": "临时",
    }
    return mapping.get(str(v), str(v) or "未知")


def show_health(v):
    if v in (None, ""):
        return "未探测"
    return str(v)

model_name = pick(runtime.get("display_model_name"), summary.get("display_model_name"))
llama_status = show_health(runtime.get("llama_status"))

print("\n=======================================================")
print(f" 🤖 \033[1;36mLM Local AI Server ({model_name})\033[0m")
print("=======================================================")
print(f" 📦 \033[1mservice:\033[0m {service}")
print(f" 🚦 \033[1m运行状态:\033[0m {runtime_state}")
print(f" 🔁 \033[1m开机自启:\033[0m {show_enabled(enabled_state)}")
print(f" ✨ \033[1m底层引擎:\033[0m {pick(llama.get('binary'))}")
print(f" 🧠 \033[1m本地模型上下文量:\033[0m {pick(llama.get('ctx_size'))} tokens")
print(f" 🔮 \033[1m本地模型最大生成:\033[0m {pick(llama.get('n_predict'))} tokens")
print(f" 🌐 \033[1mProxy 端口:\033[0m {pick(proxy.get('url'), proxy.get('port'))}")
print(f" 🦙 \033[1mllama 端口:\033[0m {pick(llama.get('url'), llama.get('port'))}  (health={llama_status})")
provider_key = pick(cloud.get('provider'))
provider_label = pick(cloud.get('provider_label'))
provider_text = provider_key if provider_label in {'-', provider_key} else f"{provider_key} ({provider_label})"
print(f" ☁️  \033[1m云模型提供方:\033[0m {provider_text}")
print(f" 🔗 \033[1m云 API:\033[0m {pick(cloud.get('api_base'))}")
aliases = cloud.get("aliases", {})
if aliases:
    print(f" 🏷️  \033[1mCC 云模型别名:\033[0m sonnet={pick(aliases.get('sonnet'))} opus={pick(aliases.get('opus'))} haiku={pick(aliases.get('haiku'))}")
print(f" 🧷 \033[1mprovider 配置:\033[0m {os.path.expanduser(os.environ.get('LM_PROVIDER_ENV', '~/.config/lm/provider.env'))}")
print(f" 🧾 \033[1m模型文件:\033[0m {pick(llama.get('model_file'), os.path.basename(str(llama.get('model_path', ''))))}")
print(f" 📁 \033[1m模型路径:\033[0m {pick(llama.get('model_path'))}")
print(f" 📝 \033[1m历史日志:\033[0m {pick(logs.get('history'))}")
if pids:
    print(f" 🆔 \033[1m进程 PID:\033[0m proxy={pick(pids.get('proxy'))} llama={pick(pids.get('llama'))}")
print("-------------------------------------------------------")
print(" ℹ️  \033[1m说明:\033[0m 上面的上下文量和最大生成只对应本地 llama.cpp 模型；云端 Claude 供应商的上下文/输出上限由各自上游决定。")
print("-------------------------------------------------------")
print(" 💡 \033[1;33m快捷命令指南:\033[0m")
print("   \033[1mlm start\033[0m        - 🚀 启动服务并等待接口 ready")
print("   \033[1mlm stop\033[0m         - 🛑 停止服务")
print("   \033[1mlm restart\033[0m      - 🔄 重启服务并等待接口 ready")
print("   \033[1mlm status\033[0m       - 📊 查看 systemd 状态")
print("   \033[1mlm log\033[0m          - 📜 实时看 journal 日志")
print("   \033[1mlm enable\033[0m       - ✅ 开启开机自启动")
print("   \033[1mlm disable\033[0m      - ⛔ 关闭开机自启动")
print("   \033[1mlm is-enabled\033[0m   - 🔍 查看是否开机自启")
print("   \033[1mlm config\033[0m       - 🧩 查看真实运行参数")
print("   \033[1mlm cc\033[0m           - ☁️  查看 Claude Code 当前云供应商与别名")
print("   \033[1mlm cc sub2\033[0m      - 🔀 永久切 Claude Code -> sub2api，云模型别名变为 sub2-*")
print("   \033[1mlm cc or\033[0m        - 🔀 永久切 Claude Code -> OpenRouter，云模型别名变为 or-*")
print("   \033[1mlm restart\033[0m      - ♻️  重启系统级 lm-server.service，让新 provider 立即生效")
print("=======================================================\n")
PY
}

cmd="${1:-}"
case "$cmd" in
  ""|help)
    print_panel
    ;;
  start)
    sudo systemctl start "$SERVICE"
    cfg_json="$(load_config_json 2>/dev/null || echo '{}')"
    proxy_port="$(extract_proxy_port "$cfg_json")"
    if wait_until_ready "$proxy_port"; then
      echo "🚀 LM Server 已就绪。"
    else
      echo "⏳ 服务进程已启动，但接口暂未 ready。可执行 lm 或 lm log 继续查看。"
      exit 1
    fi
    ;;
  stop)
    sudo systemctl stop "$SERVICE"
    echo "🛑 LM Server 已停止。"
    ;;
  restart)
    sudo systemctl restart "$SERVICE"
    cfg_json="$(load_config_json 2>/dev/null || echo '{}')"
    proxy_port="$(extract_proxy_port "$cfg_json")"
    if wait_until_ready "$proxy_port"; then
      echo "🔄 LM Server 已重启并就绪。"
    else
      echo "⏳ 服务进程已重启，但接口暂未 ready。可执行 lm 或 lm log 继续查看。"
      exit 1
    fi
    ;;
  status)
    systemctl status "$SERVICE"
    ;;
  log)
    journalctl -u "$SERVICE" -f
    ;;
  enable|boot-on|autostart-on)
    sudo systemctl enable "$SERVICE"
    echo "✅ 已开启开机自启动。"
    ;;
  disable|boot-off|autostart-off)
    sudo systemctl disable "$SERVICE"
    echo "⛔ 已关闭开机自启动。"
    ;;
  is-enabled|boot-status)
    systemctl is-enabled "$SERVICE"
    ;;
  cc)
    subcmd="${2:-}"
    case "$subcmd" in
      ""|show|current|list)
        cfg_json="$(load_config_json 2>/dev/null || echo '{}')"
        proxy_port="$(extract_proxy_port "$cfg_json")"
        runtime_json="$(load_runtime_json "$proxy_port")"
        print_provider_list "${runtime_json:-$cfg_json}"
        ;;
      sub2|or)
        provider="$(normalize_provider_name "$subcmd")"
        switch_provider_and_restart "$provider"
        ;;
      *)
        echo "❌ 未知 cc 子命令: $subcmd"
        echo "💡 用法: lm cc | lm cc sub2 | lm cc or"
        exit 1
        ;;
    esac
    ;;
  provider)
    subcmd="${2:-}"
    case "$subcmd" in
      ""|show|current|list)
        cfg_json="$(load_config_json 2>/dev/null || echo '{}')"
        proxy_port="$(extract_proxy_port "$cfg_json")"
        runtime_json="$(load_runtime_json "$proxy_port")"
        print_provider_list "${runtime_json:-$cfg_json}"
        ;;
      use)
        provider="$(normalize_provider_name "${3:-}" || true)"
        if [ -z "$provider" ]; then
          echo "❌ 不支持的 provider: ${3:-<empty>}"
          echo "💡 可选: sub2 | or"
          exit 1
        fi
        switch_provider_and_restart "$provider"
        ;;
      *)
        echo "❌ 未知 provider 子命令: $subcmd"
        echo "💡 推荐改用: lm cc | lm cc sub2 | lm cc or"
        exit 1
        ;;
    esac
    ;;
  config|info)
    print_panel
    ;;
  *)
    echo "❌ 未知命令: $cmd"
    echo "💡 输入 lm 查看帮助面板。"
    exit 1
    ;;
esac
