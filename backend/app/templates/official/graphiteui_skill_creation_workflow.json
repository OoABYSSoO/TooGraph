{
  "template_id": "graphiteui_skill_creation_workflow",
  "label": "创建自定义 Skill",
  "description": "需求澄清、样例确认、Skill 文件生成、脚本测试修复和人工批准写入的自定义 Skill 创作图模板。",
  "default_graph_name": "创建自定义 Skill",
  "state_schema": {
    "skill_request": {
      "name": "用户需求",
      "description": "用户想创建的 Skill 能力、输入输出期望和限制。",
      "type": "text",
      "value": "我想要一个把会议纪要整理成待办清单的 Skill",
      "color": "#d97706",
      "binding": null
    },
    "existing_capability": {
      "name": "已有能力",
      "description": "能力选择技能从当前启用模板和 Skill 中选择出的单个可用能力候选；这里作为审查上下文保存，不触发动态执行。",
      "type": "json",
      "value": { "kind": "none" },
      "color": "#2563eb",
      "binding": {
        "kind": "skill_output",
        "skillKey": "graphiteui_capability_selector",
        "nodeId": "select_existing_capability",
        "fieldKey": "capability",
        "managed": true
      }
    },
    "requirement_review": {
      "name": "需求评估",
      "description": "对需求是否清晰、是否已有能力可复用、是否继续创建 Skill 的结构化判断。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "creation_decision": {
      "name": "创建决策",
      "description": "是否继续创建新 Skill 的结构化决策。",
      "type": "json",
      "value": {},
      "color": "#0f766e",
      "binding": null
    },
    "clarification_questions": {
      "name": "澄清问题",
      "description": "当需求不够清晰时，面向用户提出的问题和选项。",
      "type": "markdown",
      "value": "",
      "color": "#0891b2",
      "binding": null
    },
    "clarification_answer": {
      "name": "用户澄清回答",
      "description": "用户对澄清问题的回答，可以选择选项，也可以自由补充。",
      "type": "markdown",
      "value": "",
      "color": "#d97706",
      "binding": null
    },
    "confirmed_skill_requirement": {
      "name": "确认后的需求",
      "description": "经过澄清后确认的 Skill 需求、边界、输入输出和约束。",
      "type": "markdown",
      "value": "",
      "color": "#16a34a",
      "binding": null
    },
    "example_io": {
      "name": "示例输入输出",
      "description": "用于给用户确认的示例输入、预期输出和边界示例。",
      "type": "markdown",
      "value": "",
      "color": "#7c3aed",
      "binding": null
