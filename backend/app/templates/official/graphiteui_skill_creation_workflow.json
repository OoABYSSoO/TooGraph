  "nodes": {
    "input_skill_request": {
      "kind": "input",
      "name": "输入需求",
      "description": "提供想创建的 Skill 需求。",
      "ui": {
        "position": { "x": 40, "y": 520 },
        "collapsed": false,
        "size": { "width": 320, "height": 190 }
      },
      "reads": [],
      "writes": [{ "state": "skill_request", "mode": "replace" }],
      "config": {
        "value": "我想要一个把会议纪要整理成待办清单的 Skill",
        "boundaryType": "text"
      }
    },
    "select_existing_capability": {
      "kind": "agent",
      "name": "检查已有能力",
      "description": "从启用的模板和 Skill 中检查是否已有能力能满足目标需求。",
      "ui": {
        "position": { "x": 440, "y": 470 },
        "collapsed": false,
        "size": { "width": 420, "height": 280 }
      },
      "reads": [{ "state": "skill_request", "required": true }],
      "writes": [{ "state": "existing_capability", "mode": "replace" }],
      "config": {
        "skillKey": "graphiteui_capability_selector",
        "skillBindings": [
          {
            "skillKey": "graphiteui_capability_selector",
            "outputMapping": {
              "capability": "existing_capability"
            }
          }
        ],
        "skillInstructionBlocks": {
          "graphiteui_capability_selector": {
            "skillKey": "graphiteui_capability_selector",
            "title": "能力选择 skill instruction",
            "content": "你已绑定 GraphiteUI Capability Selector。这里要检查的是用户想创建的目标 Skill 需求是否已经能被现有启用能力满足；不要因为当前流程本身是创建 Skill 的模板就选择 graphiteui_skill_creation_workflow。优先选择真正可直接满足目标需求的图模板，其次选择 Skill；没有合适能力时选择 {\"kind\":\"none\"}。",
            "source": "node.override"
          }
        },
        "taskInstruction": "根据 skill_request 检查当前启用的能力清单。只选择能直接完成用户目标需求的能力；不要选择本模板自身作为答案。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.1
      }
    },
    "review_requirement": {
      "kind": "agent",
      "name": "评估需求",
      "description": "判断需求是否清晰，是否需要澄清，以及是否继续创建新 Skill。",
      "ui": {
        "position": { "x": 940, "y": 430 },
        "collapsed": false,
        "size": { "width": 440, "height": 320 }
      },
      "reads": [
        { "state": "skill_request", "required": true },
        { "state": "existing_capability", "required": false }
      ],
      "writes": [
        { "state": "requirement_review", "mode": "replace" },
        { "state": "creation_decision", "mode": "replace" },
        { "state": "confirmed_skill_requirement", "mode": "replace" }
      ],
      "config": {
        "skillKey": "",
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "评估用户是否真的需要创建新 Skill。requirement_review 必须写 JSON 对象，包含 needs_clarification(boolean)、existing_capability_summary(string)、unclear_points(array)、questions(array)、reason(string)。如果 existing_capability 不是 none 且可能已经满足需求，应把 needs_clarification 设为 true，并在 questions 中询问用户是否仍要创建新 Skill。creation_decision 必须写 JSON 对象，包含 approved_to_create(boolean)、reason(string)；除非已有能力明显满足且用户没有表达仍要创建，否则默认 approved_to_create 为 true。confirmed_skill_requirement 写 Markdown，概括当前已确认的目标、输入、输出、权限、是否需要 before_llm.py、是否需要 after_llm.py、是否需要第三方依赖和限制。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "need_clarification": {
      "kind": "condition",
      "name": "是否需要澄清",
      "description": "需求不清晰或已有能力可能已满足时，先让用户确认。",
      "ui": {
        "position": { "x": 1460, "y": 470 },
        "collapsed": false,
        "size": { "width": 300, "height": 180 }
      },
      "reads": [{ "state": "requirement_review", "required": true }],
      "writes": [],
      "config": {
        "branches": ["true", "false", "exhausted"],
        "loopLimit": 5,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.requirement_review.needs_clarification",
          "operator": "==",
          "value": true
        }
      }
    },
    "ask_clarification": {
      "kind": "agent",
      "name": "生成澄清问题",
      "description": "把不清晰的点转成用户容易回答的选择题和少量开放问题。",
      "ui": {
        "position": { "x": 1840, "y": 170 },
        "collapsed": false,
        "size": { "width": 440, "height": 300 }
      },
      "reads": [
        { "state": "skill_request", "required": true },
        { "state": "existing_capability", "required": false },
        { "state": "requirement_review", "required": true }
      ],
      "writes": [{ "state": "clarification_questions", "mode": "replace" }],
      "config": {
        "skillKey": "",
        "skillBindings": [],
        "skillInstructionBlocks": {},
        "taskInstruction": "根据 requirement_review 生成需要用户回答的澄清问题。优先用带选项的问题，每题给 2 到 4 个选项；允许用户不认可选项并自由补充。问题应覆盖输入格式、输出格式、是否需要确定性脚本、权限范围、失败处理、依赖和是否已有能力已经足够。最后明确请用户在“用户澄清回答”中作答。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "high",
        "temperature": 0.2
      }
    },
    "merge_clarification": {
      "kind": "agent",
      "name": "合并澄清回答",
      "description": "把用户回答合并成确认后的需求和创建决策。",
      "ui": {
        "position": { "x": 2340, "y": 170 },
        "collapsed": false,
        "size": { "width": 440, "height": 300 }
      },
      "reads": [
        { "state": "skill_request", "required": true },
        { "state": "existing_capability", "required": false },
        { "state": "clarification_questions", "required": true },
