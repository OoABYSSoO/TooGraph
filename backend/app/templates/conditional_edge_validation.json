{
  "template_id": "conditional_edge_validation",
  "label": "条件分支",
  "description": "Route a score through true, false, or exhausted conditional branches.",
  "default_graph_name": "条件分支",
  "state_schema": {
    "state_1": {
      "name": "score",
      "description": "Numeric score used by the condition node.",
      "type": "number",
      "value": 80,
      "color": "#d97706"
    },
    "state_2": {
      "name": "pass_message",
      "description": "Message shown when the score passes the threshold.",
      "type": "text",
      "value": "通过：score >= 60，进入 true 分支。",
      "color": "#15803d"
    },
    "state_3": {
      "name": "fail_message",
      "description": "Message shown when the score misses the threshold.",
      "type": "text",
      "value": "未通过：score < 60，进入 false 分支。",
      "color": "#b91c1c"
    },
    "state_4": {
      "name": "exhausted_message",
      "description": "Message shown when the loop limit is exhausted.",
      "type": "text",
      "value": "循环次数已耗尽，进入 exhausted 分支。",
      "color": "#78716c"
    }
  },
  "nodes": {
    "input_score": {
      "kind": "input",
      "name": "input_score",
      "description": "Provide the score checked by the condition node.",
      "ui": {
        "position": { "x": 80, "y": 80 },
        "collapsed": false
      },
      "writes": [
        { "state": "state_1", "mode": "replace" }
      ],
      "config": {
        "value": 80
      }
    },
    "input_pass_message": {
      "kind": "input",
      "name": "input_pass_message",
      "description": "Provide the output text for the true branch.",
      "ui": {
        "position": { "x": 80, "y": 560 },
        "collapsed": false
      },
      "writes": [
        { "state": "state_2", "mode": "replace" }
      ],
      "config": {
        "value": "通过：score >= 60，进入 true 分支。"
      }
    },
    "input_fail_message": {
      "kind": "input",
      "name": "input_fail_message",
      "description": "Provide the output text for the false branch.",
      "ui": {
        "position": { "x": 760, "y": 560 },
        "collapsed": false
      },
      "writes": [
        { "state": "state_3", "mode": "replace" }
      ],
      "config": {
        "value": "未通过：score < 60，进入 false 分支。"
      }
    },
    "input_exhausted_message": {
      "kind": "input",
      "name": "input_exhausted_message",
      "description": "Provide the output text for the exhausted branch.",
      "ui": {
        "position": { "x": 80, "y": 1040 },
        "collapsed": false
      },
      "writes": [
        { "state": "state_4", "mode": "replace" }
      ],
      "config": {
        "value": "循环次数已耗尽，进入 exhausted 分支。"
      }
    },
    "score_gate": {
      "kind": "condition",
      "name": "score_gate",
      "description": "Route through true, false, or exhausted based on score >= 60.",
      "ui": {
        "position": { "x": 760, "y": 80 },
        "collapsed": false
      },
      "reads": [
        { "state": "state_1", "required": true }
      ],
      "config": {
        "branches": ["true", "false", "exhausted"],
        "loopLimit": 5,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "state_1",
          "operator": ">=",
          "value": 60
        }
      }
    },
    "output_pass": {
      "kind": "output",
      "name": "output_pass",
      "description": "Show the true-branch output.",
      "ui": {
        "position": { "x": 1440, "y": 80 },
        "collapsed": false
      },
      "reads": [
        { "state": "state_2", "required": true }
      ],
      "config": {
        "displayMode": "auto",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_fail": {
      "kind": "output",
      "name": "output_fail",
      "description": "Show the false-branch output.",
      "ui": {
        "position": { "x": 1440, "y": 560 },
        "collapsed": false
      },
      "reads": [
        { "state": "state_3", "required": true }
      ],
      "config": {
        "displayMode": "auto",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    },
    "output_exhausted": {
      "kind": "output",
      "name": "output_exhausted",
      "description": "Show the exhausted-branch output.",
      "ui": {
        "position": { "x": 1440, "y": 1040 },
        "collapsed": false
      },
      "reads": [
        { "state": "state_4", "required": true }
      ],
      "config": {
        "displayMode": "auto",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_score",
      "target": "score_gate"
    }
  ],
  "conditional_edges": [
    {
      "source": "score_gate",
      "branches": {
        "true": "output_pass",
        "false": "output_fail",
        "exhausted": "output_exhausted"
      }
    }
  ],
  "metadata": {
    "graphiteui_state_key_counter": 4
  }
}
