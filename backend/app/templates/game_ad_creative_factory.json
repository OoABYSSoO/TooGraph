    "collect_game_market_signals": {
      "kind": "agent",
      "name": "collect_game_market_signals",
      "description": "Collect public game-market RSS context and public ad media artifacts.",
      "ui": { "position": { "x": 720, "y": 440 }, "collapsed": false },
      "reads": [
        { "state": "state_1", "required": true },
        { "state": "state_2", "required": false },
        { "state": "state_3", "required": false },
        { "state": "state_4", "required": false }
      ],
      "writes": [
        { "state": "state_7", "mode": "replace" },
        { "state": "state_8", "mode": "replace" },
        { "state": "state_9", "mode": "replace" },
        { "state": "state_10", "mode": "replace" },
        { "state": "state_11", "mode": "replace" }
      ],
      "config": {
        "skills": ["game_ad_research_collector"],
        "skillBindings": [
          {
            "skillKey": "game_ad_research_collector",
            "trigger": "before_agent",
            "inputMapping": {
              "genre": "state_1",
              "search_terms": "state_2",
              "country": "state_3",
              "days_back": "state_4"
            },
            "outputMapping": {
              "summary": "state_7",
              "rss_items": "state_8",
              "ad_items": "state_9",
              "downloaded_files": "state_10",
              "source_documents": "state_11"
            },
            "config": {
              "top_fetch_per_term": 2,
              "max_news_items": 12,
              "enable_rss": "true",
              "enable_ads": "true",
              "use_playwright": "true"
            }
          }
        ],
        "taskInstruction": "根据 game_ad_research_collector 技能结果，保留 research_summary、rss_items、ad_items、downloaded_video_files、source_documents。summary 要说明采集到的新闻数量、广告搜索记录、下载视频 local_path，以及任何 warning。不要编造 URL 或本地路径。"
      }
    },
    "analyze_video_patterns": {
      "kind": "agent",
      "name": "analyze_video_patterns",
      "description": "Analyze downloaded local videos and summarize reusable creative patterns.",
      "ui": { "position": { "x": 1360, "y": 440 }, "collapsed": false },
      "reads": [
        { "state": "state_1", "required": true },
        { "state": "state_7", "required": false },
        { "state": "state_8", "required": false },
        { "state": "state_9", "required": false },
        { "state": "state_10", "required": false },
        { "state": "state_11", "required": false }
      ],
      "writes": [
        { "state": "state_12", "mode": "replace" },
        { "state": "state_13", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "taskInstruction": "分析 downloaded_video_files 中的本地视频 artifact；如果没有视频，则基于 ad_items、rss_items 和 source_documents 做文本侧分析。输出 video_analysis_results 为 JSON 数组，每项包含 source、local_path、hook、visual_structure、gameplay_or_story_moment、emotion_trigger、cta、risks。输出 pattern_summary 为中文 markdown，总结可复用广告模式、常见开场、节奏、视觉符号和避免事项。"
      }
    },
    "build_creative_brief": {
      "kind": "agent",
      "name": "build_creative_brief",
      "description": "Build an actionable creative brief from research and pattern analysis.",
      "ui": { "position": { "x": 2000, "y": 440 }, "collapsed": false },
      "reads": [
        { "state": "state_1", "required": true },
        { "state": "state_5", "required": true },
        { "state": "state_8", "required": false },
        { "state": "state_9", "required": false },
        { "state": "state_12", "required": false },
        { "state": "state_13", "required": false }
      ],
      "writes": [{ "state": "state_14", "mode": "replace" }],
      "config": {
        "skills": [],
        "taskInstruction": "为 genre 和 creative_goal 生成一份可执行 creative_brief。必须包含目标受众、核心冲突、情绪钩子、前三秒 hook、角色/场景建议、画面节奏、差异化方向、素材证据引用、风险限制。用中文 markdown 输出。"
      }
    },
    "generate_creative_package": {
      "kind": "agent",
      "name": "generate_creative_package",
      "description": "Generate script variants, storyboard package, and video prompts.",
      "ui": { "position": { "x": 2640, "y": 440 }, "collapsed": false },
      "reads": [
        { "state": "state_1", "required": true },
        { "state": "state_5", "required": true },
        { "state": "state_6", "required": false },
        { "state": "state_14", "required": true },
        { "state": "state_20", "required": false }
      ],
      "writes": [
        { "state": "state_15", "mode": "replace" },
        { "state": "state_16", "mode": "replace" },
        { "state": "state_17", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "taskInstruction": "基于 creative_brief、variants_count 和 revision_feedback 生成创意包。script_variants 必须是 JSON 数组，每项包含 variant_id、title、angle、target_emotion、15s_shots、voiceover_en、on_screen_text_en、cta_en、test_hypothesis。storyboard_package 用中文 markdown 输出每个版本的关键帧、镜头、构图、角色、UI 文案、图片生成提示词。video_prompt_package 用中文 markdown 输出每个版本两类视频提示词：一类是 15 秒连续视频提示词，一类是基于分镜的分段视频提示词。英文广告台词和屏幕文案保持英文。"
      }
    },
    "review_creative_package": {
      "kind": "agent",
      "name": "review_creative_package",
      "description": "Score generated creative package and decide whether to revise.",
      "ui": { "position": { "x": 3280, "y": 440 }, "collapsed": false },
      "reads": [
        { "state": "state_5", "required": true },
        { "state": "state_14", "required": true },
        { "state": "state_15", "required": true },
        { "state": "state_16", "required": true },
        { "state": "state_17", "required": true }
      ],
      "writes": [
        { "state": "state_18", "mode": "replace" },
        { "state": "state_19", "mode": "replace" },
        { "state": "state_20", "mode": "replace" },
        { "state": "state_21", "mode": "replace" },
        { "state": "state_22", "mode": "replace" }
      ],
      "config": {
        "skills": [],
        "taskInstruction": "评审创意包。review_results 输出 JSON 数组，每项包含 variant_id、hook_score、clarity_score、genre_fit_score、production_feasibility_score、risk_score、total_score、feedback。best_variant 输出最高分版本。needs_revision 当最高分低于 7.8 或存在严重制作/合规风险时为 true，否则 false。revision_feedback 用中文 markdown 给出下一轮具体修改点。final_summary 用中文 markdown 汇总最佳版本、评分、brief、脚本、分镜和视频提示词入口。"
      }
    },
    "creative_revision_check": {
      "kind": "condition",
      "name": "creative_revision_check",
      "description": "Loop once or twice when review asks for revision.",
      "ui": { "position": { "x": 3920, "y": 440 }, "collapsed": false },
      "reads": [{ "state": "state_19", "required": false }],
      "writes": [],
      "config": {
        "branches": ["true", "false", "exhausted"],
        "loopLimit": 2,
        "branchMapping": { "true": "true", "false": "false" },
        "rule": {
          "source": "state_19",
          "operator": "==",
          "value": true
        }
      }
    },
