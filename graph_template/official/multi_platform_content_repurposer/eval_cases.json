{
  "suite": "multi_platform_content_repurposer_lightweight",
  "cases": [
    {
      "case_id": "repurposer-mock-product-update",
      "name": "产品更新一文多发 mock 改写",
      "inputs": {
        "source_content_path": "mock_data/sample_source_content.md",
        "target_platforms": "微信公众号、小红书、知乎、B站、抖音、X、YouTube",
        "historical_samples": "我常用短句，先给判断，再给例子。标题不喜欢夸张感叹号，也不喜欢万能三段式。",
        "content_goal": "把产品更新转成多平台发布内容，让读者理解新功能解决了什么具体问题，并愿意试用。",
        "human_feedback": ""
      },
      "checks": [
        {
          "kind": "rule",
          "key": "core_message_preserved",
          "description": "必须保留 local-hash baseline、citation trace 和后续限制。"
        },
        {
          "kind": "schema",
          "key": "all_target_platforms_present",
          "description": "目标平台必须全部出现在平台最终稿或发布计划中。"
        },
        {
          "kind": "schema",
          "key": "ai_tone_report_present",
          "description": "必须输出 AI 味检测和改写指令。"
        },
        {
          "kind": "rule",
          "key": "style_memory_candidates_are_candidate_only",
          "description": "风格偏好只能写为 candidate 状态记忆，不能应用为 active。"
        },
        {
          "kind": "artifact",
          "key": "final_pack_contains_manual_review_notes",
          "description": "最终包必须保留人工复核提示和限制。"
        }
      ]
    }
  ]
}
