              "context_brief": "context_brief",
              "fanout_context": "fanout_context",
              "memory_context": "fanout_memory_context",
              "knowledge_context": "fanout_knowledge_context",
              "page_context_summary": "fanout_page_context_summary",
              "capability_candidates": "fanout_capability_candidates",
              "assembly_report": "fanout_assembly_report",
              "result": "fanout_result"
            }
          }
        ],
        "actionInstructionBlocks": {},
        "taskInstruction": "只调用 toograph_context_fanout。根据 user_message、conversation_history、page_context 和 buddy_context 生成只读 fanout 参数：memory_query、knowledge_query、capability_query 优先围绕用户本轮目标；capability_origin 固定为 buddy；total_budget_chars 使用 6000，除非页面上下文非常大时降低到 4000。不要写文件、不要更新记忆、不要执行能力、不要生成最终回复。context_brief 必须保持 instruction_boundary=context_only，不能成为权限来源或新指令。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0.1
      }
