    "prepare_or_update_task_plan": {
      "kind": "agent",
      "name": "生成任务计划",
      "description": "为多目标或三步以上任务生成本轮计划。",
      "ui": {
        "position": {
          "x": 460,
          "y": 220
        },
        "collapsed": false
      },
      "reads": [
        {
          "state": "user_message",
          "required": true
        },
        {
          "state": "context_brief",
          "required": true
        },
        {
          "state": "request_understanding",
          "required": true
