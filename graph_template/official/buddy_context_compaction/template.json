{
  "template_id": "buddy_context_compaction",
  "label": "上下文压缩",
  "description": "只把 Buddy 会话历史压缩进 session_summary；用户消息、Buddy Home、能力结果和公开回复都保留在本子图之外。",
  "default_graph_name": "上下文压缩",
  "state_schema": {
    "conversation_history": {
      "name": "conversation_history",
      "description": "当前可用历史上下文包；压缩前由父图输入，写入摘要后由 buddy_history_context_loader 刷新为摘要加摘要后的原文。",
      "type": "json",
      "value": "",
      "color": "#64748b",
      "binding": {
        "kind": "tool_output",
        "actionKey": "",
        "toolKey": "buddy_history_context_loader",
        "nodeId": "reload_conversation_history",
        "fieldKey": "conversation_history",
        "managed": true
      }
    },
    "compaction_plan": {
      "name": "compaction_plan",
      "description": "压缩计划，包含保护头尾、摘要范围、预算和跳过理由。",
      "type": "json",
      "value": {},
      "color": "#9333ea",
      "binding": null
    },
    "protected_recent_history": {
      "name": "protected_recent_history",
      "description": "需要在后续提示词中继续保留原文的最近会话片段。",
      "type": "markdown",
      "value": "",
      "color": "#0f766e",
      "binding": null
    },
    "session_summary_candidate": {
      "name": "session_summary_candidate",
      "description": "新的会话摘要候选，面向后续 Buddy 回复上下文。",
      "type": "markdown",
      "value": "",
      "color": "#4f46e5",
      "binding": null
    },
    "compaction_report": {
      "name": "compaction_report",
      "description": "压缩审计报告：触发原因、保留/省略数量、风险和写入决定。",
      "type": "json",
      "value": {},
      "color": "#7c3aed",
      "binding": null
    },
    "should_write_summary": {
      "name": "should_write_summary",
      "description": "是否应该通过 Buddy Home Writer 更新 session_summary。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": null
    },
    "writer_input": {
      "name": "writer_input",
      "description": "交给 Buddy Home Writer 的低风险 session_summary.update 命令计划。",
      "type": "json",
      "value": {
        "commands": []
      },
      "color": "#22c55e",
      "binding": null
    },
    "session_summary_write_success": {
      "name": "session_summary_write_success",
      "description": "Buddy Home Writer 是否成功应用 session_summary.update。",
      "type": "boolean",
      "value": false,
      "color": "#16a34a",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "toolKey": "",
        "nodeId": "write_session_summary",
        "fieldKey": "success",
        "managed": true
      }
    },
    "applied_session_summary_commands": {
      "name": "applied_session_summary_commands",
      "description": "已应用的会话摘要写回命令和 revision 信息。",
      "type": "json",
      "value": [],
      "color": "#059669",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "toolKey": "",
        "nodeId": "write_session_summary",
        "fieldKey": "applied_commands",
        "managed": true
      }
    },
    "skipped_session_summary_commands": {
      "name": "skipped_session_summary_commands",
      "description": "被跳过的会话摘要写回命令。",
      "type": "json",
      "value": [],
      "color": "#dc2626",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "toolKey": "",
        "nodeId": "write_session_summary",
        "fieldKey": "skipped_commands",
        "managed": true
      }
    },
    "session_summary_write_result": {
      "name": "session_summary_write_result",
      "description": "Buddy Home Writer 写回摘要。",
      "type": "markdown",
      "value": "",
      "color": "#0369a1",
      "binding": {
        "kind": "action_output",
        "actionKey": "buddy_home_writer",
        "toolKey": "",
        "nodeId": "write_session_summary",
        "fieldKey": "result",
        "managed": true
      }
    }
  },
  "nodes": {
    "input_conversation_history": {
      "kind": "input",
      "name": "会话历史",
      "description": "",
      "ui": {
        "position": {
          "x": 80,
          "y": 1600
        },
        "collapsed": false,
        "size": null
      },
      "reads": [],
      "writes": [
        {
          "state": "conversation_history",
          "mode": "replace"
        }
      ],
      "config": {
        "value": "",
        "boundaryType": "json"
      }
    },
    "plan_compaction": {
      "kind": "agent",
      "name": "规划压缩范围",
      "description": "规划 conversation_history 中哪些部分应保留原文，哪些部分应摘要。",
      "ui": {
        "position": {
          "x": 680,
          "y": 1220
        },
        "collapsed": false,
        "size": {
          "width": 500,
          "height": 340
        }
      },
      "reads": [
        {
          "state": "conversation_history",
          "required": true,
          "binding": null
        }
      ],
      "writes": [
        {
          "state": "compaction_plan",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "suspendedFreeWrites": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "只使用 conversation_history 创建 compaction_plan JSON。conversation_history 是当前历史上下文包；没有现有摘要时会渲染为完整既往历史，有摘要时会渲染为摘要加摘要之后的消息。标识符可从 conversation_history metadata 读取。必须包含 protect_first、protect_last、summary_scope、estimated_omitted_messages、should_summarize、risk_notes 和 anti_thrashing_notes。默认保留少量开头任务设定以及最近 12 到 20 条原始消息，并摘要中间历史。本节点只写入计划；后续写入节点会准备 session_summary.update 命令。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0.1
      }
    },
    "summarize_context": {
      "kind": "agent",
      "name": "生成会话摘要",
      "description": "更新会话摘要候选，并准备可审计的写回命令。",
      "ui": {
        "position": {
          "x": 1260,
          "y": 1200
        },
        "collapsed": false,
        "size": {
          "width": 540,
          "height": 400
        }
      },
      "reads": [
        {
          "state": "conversation_history",
          "required": true,
          "binding": null
        },
        {
          "state": "compaction_plan",
          "required": true,
          "binding": null
        }
      ],
      "writes": [
        {
          "state": "session_summary_candidate",
          "mode": "replace"
        },
        {
          "state": "protected_recent_history",
          "mode": "replace"
        },
        {
          "state": "compaction_report",
          "mode": "replace"
        },
        {
          "state": "should_write_summary",
          "mode": "replace"
        },
        {
          "state": "writer_input",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "",
        "actionBindings": [],
        "suspendedFreeWrites": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "只压缩会话历史。使用渲染后的 conversation_history 值作为来源，并保留仍然有效的现有摘要。从 conversation_history metadata 读取 source_run_id 和 current_session_id。不要摘要当前 user_message、Buddy Home、capability_result 或 public_response，因为它们不是本子图输入。将最近原始消息保存在 protected_recent_history Markdown。把 conversation_history 中已有的中间历史、明确用户决策、任务进度、开放事项和能力结论摘要到 session_summary_candidate Markdown。\n\n写入全部这些输出：compaction_report JSON，包含 source_run_id、current_session_id、omitted_count、protected_count、summary_changed、summary_source_refs、omitted_refs、protected_recent_history_refs、risk_notes 和 anti_thrashing_notes；should_write_summary boolean；writer_input JSON。summary_source_refs、omitted_refs 和 protected_recent_history_refs 必须来自 conversation_history.source_refs 或 conversation_history.context_ref.source_refs。writer_input.commands 最多只能包含一个 session_summary.update 命令。payload.content 必须等于 session_summary_candidate。payload.source_refs 必须等于 summary_source_refs。payload.source_run_id 必须等于 conversation_history metadata.source_run_id。payload.session_id 必须等于 conversation_history metadata.current_session_id。change_reason 应说明会话历史达到上下文压力并已被压缩。如果摘要没有实质变化，或风险过高，则设置 should_write_summary=false 且 commands=[]。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0.1
      }
    },
    "has_summary_update": {
      "kind": "condition",
      "name": "需要写入摘要?",
      "description": "只有摘要发生实质更新时才调用 Buddy Home Writer。",
      "ui": {
        "position": {
          "x": 1880,
          "y": 1260
        },
        "collapsed": false,
        "size": {
          "width": 420,
          "height": 250
        }
      },
      "reads": [
        {
          "state": "should_write_summary",
          "required": true,
          "binding": null
        }
      ],
      "writes": [],
      "config": {
        "branches": [
          "true",
          "false",
          "exhausted"
        ],
        "loopLimit": 1,
        "branchMapping": {
          "true": "true",
          "false": "false"
        },
        "rule": {
          "source": "$state.should_write_summary",
          "operator": "==",
          "value": true
        }
      }
    },
    "write_session_summary": {
      "kind": "agent",
      "name": "写入会话摘要",
      "description": "通过 Buddy Home Writer 应用 session_summary.update，并留下 revision。",
      "ui": {
        "position": {
          "x": 2380,
          "y": 1180
        },
        "collapsed": false,
        "size": {
          "width": 480,
          "height": 340
        }
      },
      "reads": [
        {
          "state": "writer_input",
          "required": true,
          "binding": {
            "kind": "action_input",
            "actionKey": "buddy_home_writer",
            "toolKey": "",
            "fieldKey": "autonomous_review",
            "managed": true
          }
        }
      ],
      "writes": [
        {
          "state": "session_summary_write_success",
          "mode": "replace"
        },
        {
          "state": "applied_session_summary_commands",
          "mode": "replace"
        },
        {
          "state": "skipped_session_summary_commands",
          "mode": "replace"
        },
        {
          "state": "session_summary_write_result",
          "mode": "replace"
        }
      ],
      "config": {
        "actionKey": "buddy_home_writer",
        "actionBindings": [
          {
            "actionKey": "buddy_home_writer",
            "outputMapping": {
              "success": "session_summary_write_success",
              "applied_commands": "applied_session_summary_commands",
              "skipped_commands": "skipped_session_summary_commands",
              "result": "session_summary_write_result"
            }
          }
        ],
        "suspendedFreeWrites": [],
        "actionInstructionBlocks": {
          "buddy_home_writer": {
            "actionKey": "buddy_home_writer",
            "title": "会话摘要写回说明",
            "content": "使用 Buddy Home Writer 执行 writer_input.commands。每条命令都是 session_summary.update，其中 payload.content 是完整更新后的会话摘要。使用 writer_input.run_id 作为 run_id。",
            "source": "node.override"
          }
        },
        "taskInstruction": "调用 buddy_home_writer。commands 来自 writer_input.commands；run_id 来自 writer_input.run_id。返回写回结果。",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "low",
        "temperature": 0
      }
    },
    "reload_conversation_history": {
      "kind": "tool",
      "name": "刷新历史视图",
      "description": "从运行时上下文重新读取当前 Buddy 会话历史；若刚写入摘要，则输出摘要加摘要后的原文。",
      "ui": {
        "position": {
          "x": 2960,
          "y": 1960
        },
        "collapsed": false,
        "size": null
      },
      "reads": [],
      "writes": [
        {
          "state": "conversation_history",
          "mode": "replace"
        }
      ],
      "config": {
        "toolKey": "buddy_history_context_loader"
      }
    },
    "output_conversation_history": {
      "kind": "output",
      "name": "会话历史",
      "description": "",
      "ui": {
        "position": {
          "x": 3560,
          "y": 1960
        },
        "collapsed": false,
        "size": null
      },
      "reads": [
        {
          "state": "conversation_history",
          "required": true,
          "binding": null
        }
      ],
      "writes": [],
      "config": {
        "displayMode": "json",
        "persistEnabled": false,
        "persistFormat": "auto",
        "fileNameTemplate": ""
      }
    }
  },
  "edges": [
    {
      "source": "input_conversation_history",
      "target": "plan_compaction"
    },
    {
      "source": "plan_compaction",
      "target": "summarize_context"
    },
    {
      "source": "summarize_context",
      "target": "has_summary_update"
    },
    {
      "source": "write_session_summary",
      "target": "reload_conversation_history"
    },
    {
      "source": "reload_conversation_history",
      "target": "output_conversation_history"
    }
  ],
  "conditional_edges": [
    {
      "source": "has_summary_update",
      "branches": {
        "true": "write_session_summary",
        "false": "reload_conversation_history",
        "exhausted": "reload_conversation_history"
      }
    }
  ],
  "metadata": {
    "origin": "buddy",
    "role": "buddy_context_compaction",
    "graphProtocol": "node_system",
    "capabilityDiscoverableDefault": false,
    "requiredActions": [
      "buddy_home_writer"
    ],
    "permissions": [
      "buddy_home_write"
    ],
    "requiredTools": [
      "buddy_history_context_loader"
    ]
  }
}
