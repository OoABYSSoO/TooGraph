    "decide_autonomous_review": {
      "kind": "agent",
      "name": "判断自主复盘",
      "description": "复盘已完成的可见 Buddy 运行，生成可审查的改进候选和候选记忆计划。",
      "ui": {
        "position": {
          "x": 620,
          "y": 420
        },
        "collapsed": false,
        "size": {
          "width": 460,
          "height": 320
        }
