{
  "suite": "buddy_improvement_review_workflow_core",
  "name": "Buddy 改进候选验证核心回归",
  "description": "覆盖 improvement candidate 转成验证计划、diff proposal、测试计划和 approval request 的审查合同。",
  "cases": [
    {
      "case_id": "improvement-review-requires-approval-for-template-change",
      "name": "模板改进候选必须生成审批请求",
      "description": "模拟后台复盘产出的模板改进候选，验证工作流应读取目标模板，提出验证报告和人工审批请求，不直接应用改动。",
      "inputs": {
        "source_run_id": "run_eval_improvement_source",
        "improvement_candidate": {
          "candidate_id": "cand_eval_template_recall_case",
          "kind": "template_revision",
          "source_run_id": "run_eval_improvement_source",
          "review_id": "review_eval_improvement",
          "review_run_id": "run_eval_review_fixture",
          "target_ref": {
            "kind": "template",
            "id": "buddy_autonomous_loop"
          },
          "evidence_refs": [
            {
              "source_kind": "graph_run",
              "source_id": "run_eval_improvement_source"
            }
          ],
          "risk_level": "medium",
          "expected_benefit": "让 Buddy 主循环 eval 覆盖召回失败诊断。",
          "proposed_change_summary": "为 buddy_autonomous_loop 增加一个 memory recall failure eval case，并保留 source refs 检查。",
          "approval_required": true,
          "payload": {
            "suggested_eval_case": {
              "case_id": "buddy-main-loop-recall-failure-diagnostic",
              "focus": "recall failure diagnostic"
            }
          },
          "status": "proposed"
        }
      },
      "expected": {
        "required": [
          "final_summary",
          "approval_request",
          "proposed_diff",
          "validation_report",
          "candidate_status_recommendation"
        ]
      },
      "checks": [
        {
          "kind": "schema",
          "name": "improvement_review_outputs_present",
          "target": "final_output",
          "required": [
            "final_summary",
            "approval_request",
            "proposed_diff",
            "validation_report",
            "candidate_status_recommendation"
          ]
        },
        {
          "kind": "rule",
          "key": "template_change_requires_review_and_no_direct_apply",
          "expectation": "approval_request 应说明目标模板、风险、验证步骤和需要人工确认；final_summary 应明确本模板只验证和提出 diff，不直接写入或覆盖官方模板。"
        }
      ],
      "metadata": {
        "fixture_runs": [
          {
            "run_id": "run_eval_improvement_source",
            "graph_id": "buddy_autonomous_review_fixture",
            "graph_name": "Buddy 改进候选 eval fixture",
            "status": "completed",
            "state_values": {
              "improvement_candidates": [
                {
                  "candidate_id": "cand_eval_template_recall_case",
                  "kind": "template_revision",
                  "target_ref": {
                    "kind": "template",
                    "id": "buddy_autonomous_loop"
                  },
                  "risk_level": "medium",
                  "approval_required": true
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
