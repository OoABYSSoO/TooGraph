      "config": {
        "actionKey": "",
        "actionBindings": [],
        "suspendedFreeWrites": [],
        "actionInstructionBlocks": {},
        "taskInstruction": "Generate two states only: retrieval_query text and retrieval_filters JSON. retrieval_query should preserve the user's factual intent, include key entities, dates, places, policy names, and synonyms when useful, but avoid adding unsupported assumptions. retrieval_filters must always include source_kind='knowledge_document'. Use collection_id as the knowledge boundary: if collection_id is non-empty, set metadata_filter.collection to the exact collection_id. Do not expose filters, model refs, limits, or ranking internals as user-facing outputs.",
        "modelSource": "global",
        "model": "",
        "thinkingMode": "medium",
        "temperature": 0.1
      }
    },
