{
  "template_id": "knowledge_retrieval_qa",
  "label": "知识库检索问答",
  "description": "面向自主循环调用的知识库问答子图：接收用户问题和 collection_id，召回已入库知识库证据，并输出可直接进入上下文的答案、证据摘要、引用来源、覆盖度和缺失证据；不输出 answer_package JSON，不写入知识库或记忆。",
  "default_graph_name": "知识库检索问答",
  "state_schema": {
    "user_question": {
