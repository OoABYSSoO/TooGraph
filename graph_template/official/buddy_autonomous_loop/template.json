      "value": {},
      "color": "#0284c7",
      "binding": {
        "kind": "capability_result",
        "actionKey": "",
        "toolKey": "",
        "nodeId": "execute_capability",
        "fieldKey": "result_package",
        "managed": true
      }
    },
    "show_result_package": {
      "name": "展示结果包",
      "description": "为 true 时紧接着把 capability_result 作为下一条可见消息展示给用户，并结束本轮循环；它不是“模型是否能回答”，而是“是否原样展示结果包”。",
